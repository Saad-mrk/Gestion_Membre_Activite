@model IEnumerable<Gestion_des_membres_et_activitťs_d_un_club.Models.Inscription>

@{
    ViewData["Title"] = "Liste des inscriptions";
}

<h2>Liste des inscriptions</h2>

<div class="row mb-4 align-items-center">
    <div class="col-md-6">
        <a asp-action="Create" class="btn btn-warning d-inline-flex align-items-center gap-2 shadow-sm">
            <span>&#128221;</span> Inscrire un membre
        </a>
    </div>
    <div class="col-md-6">
        <form asp-action="Index" method="get" class="input-group shadow-sm rounded-pill overflow-hidden">
            <input type="text" name="searchString" class="form-control border-0 ps-4" 
                   placeholder="Rechercher une inscription (nom, activitť)..." 
                   value="@ViewData["CurrentFilter"]" 
                   list="inscriptionsList"
                   style="height: 48px; background-color: #f8f9fa;" />
            <datalist id="inscriptionsList">
                @foreach (var item in Model)
                {
                    <option value="@item.Membre?.Nom"></option>
                    <option value="@item.Activite?.Nom"></option>
                }
            </datalist>
            <button type="submit" class="btn btn-warning px-4 border-0">
                <span>&#128269;</span>
            </button>
        </form>
    </div>
</div>

<table class="table table-striped table-bordered">
    <thead>
        <tr>
            <th>Membre</th>
            <th>Activitť</th>
            <th>Date d'inscription</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Membre?.Nom @item.Membre?.Prenom</td>
                <td>@item.Activite?.Nom</td>
                <td>@item.DateInscription.ToString("dd/MM/yyyy HH:mm")</td>
                <td>
                    <div class="d-flex gap-2">
                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-warning">Modifier</a>
                        <form asp-action="Delete" asp-route-id="@item.Id" method="post" onsubmit="return confirm('Souhaitez-vous vraiment annuler cette inscription ?');">
                                @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-sm btn-outline-danger">Supprimer</button>
                        </form>
                    </div>
                </td>
            </tr>
        }
    </tbody>

</table>
    