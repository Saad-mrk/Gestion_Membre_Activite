@model Gestion_des_membres_et_activités_d_un_club.Models.Inscription

<h2>Inscrire un Membre à une Activité</h2>

@using (Html.BeginForm()) 
{
    @Html.AntiForgeryToken()

    <div class="form-group mb-3">
        <label class="control-label">Sélectionner un Membre</label>
        @Html.DropDownList("MembreId", (SelectList)ViewBag.MembreId, "--- Choisissez un membre ---", new { @class = "form-control" })
        @Html.ValidationMessageFor(m => m.MembreId, "", new { @class = "text-danger" })
    </div>

    <div class="form-group mb-3">
        <label class="control-label">Sélectionner une Activité</label>
        @Html.DropDownList("ActiviteId", (SelectList)ViewBag.ActiviteId, "--- Choisissez une activité ---", new { @class = "form-control" })
        @Html.ValidationMessageFor(m => m.ActiviteId, "", new { @class = "text-danger" })
    </div>

    <button type="submit" class="btn btn-warning">Inscrire</button>
}