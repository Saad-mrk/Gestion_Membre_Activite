@model IEnumerable<Gestion_des_membres_et_activitťs_d_un_club.Models.Membre>

@{  
    ViewData["Title"] = "Liste des membres";
}

<h2>Liste des membres</h2>

<p>
    <a asp-action="Create" class="btn btn-primary">Ajouter un membre</a>
</p>

<table class="table table-striped table-bordered">
    <thead>     
        <tr>
            <th>Nom</th>
            <th>Prťnom</th>
            <th>Email</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Nom</td>
                <td>@item.Prenom</td>
                <td>@item.Email</td>
                <td>
                    <div class="d-flex gap-2">
                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">Modifier</a>
                        <form asp-action="Delete" asp-route-id="@item.Id" method="post" onsubmit="return confirm(' tes-vous sŻr de vouloir supprimer ce membre ?');">
                            <button type="submit" class="btn btn-sm btn-outline-danger">Supprimer</button>
                        </form>
                    </div>
                </td>
            </tr>
        }
    </tbody>

</table>
