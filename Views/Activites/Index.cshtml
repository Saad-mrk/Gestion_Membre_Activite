@model IEnumerable<Gestion_des_membres_et_activitķs_d_un_club.Models.Activite>

@{
    ViewData["Title"] = "Liste des activitķs";
}

<h2>Liste des activitķs</h2>

<div class="row mb-4 align-items-center">
    <div class="col-md-6">
        <a asp-action="Create" class="btn btn-success d-inline-flex align-items-center gap-2 shadow-sm">
            <span>&#128197;</span> Crķer une activitķ
        </a>
    </div>
    <div class="col-md-6">
        <form asp-action="Index" method="get" class="input-group shadow-sm rounded-pill overflow-hidden">
            <input type="text" name="searchString" class="form-control border-0 ps-4" 
                   placeholder="Rechercher une activitķ..." 
                   value="@ViewData["CurrentFilter"]" 
                   list="activitesList"
                   style="height: 48px; background-color: #f8f9fa;" />
            <datalist id="activitesList">
                @foreach (var item in Model.Take(8))
                {
                    <option value="@item.Nom"></option>
                }
            </datalist>
            <button type="submit" class="btn btn-success px-4 border-0">
                <span>&#128269;</span>
            </button>
        </form>
    </div>
</div>

<table class="table table-striped table-bordered">
    <thead>
        <tr>
            <th>Nom</th>
            <th>Description</th>
            <th>Date</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Nom</td>
                <td>@item.Description</td>
                <td>@item.DateActivite.ToString("dd/MM/yyyy")</td>
                <td>
                    <div class="d-flex gap-2">
                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-success">Modifier</a>
                        <form asp-action="Delete" asp-route-id="@item.Id" method="post" onsubmit="return confirm('╩tes-vous s¹r de vouloir supprimer cette activitķ ?');">
                                 @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-sm btn-outline-danger">Supprimer</button>
                        </form>
                    </div>
                </td>
            </tr>
        }
    </tbody>

</table>
                                                        