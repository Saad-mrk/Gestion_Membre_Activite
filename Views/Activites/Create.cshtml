@model Gestion_des_membres_et_activités_d_un_club.Models.Activite

<h2>Créer une Activité</h2>

@using (Html.BeginForm()) 
{
    @Html.AntiForgeryToken()

    <div class="form-group mb-3">
        @Html.LabelFor(m => m.Nom, new { @class = "control-label" })
        @Html.TextBoxFor(m => m.Nom, new { @class = "form-control" })
        @Html.ValidationMessageFor(m => m.Nom, "", new { @class = "text-danger" })
    </div>

    <div class="form-group mb-3">
        @Html.LabelFor(m => m.Description, new { @class = "control-label" })
        @Html.TextAreaFor(m => m.Description, new { @class = "form-control" })
        @Html.ValidationMessageFor(m => m.Description, "", new { @class = "text-danger" })
    </div>

    <div class="form-group mb-3">
        @Html.LabelFor(m => m.DateActivite, "Date de l'activité", new { @class = "control-label" })
        @Html.TextBoxFor(m => m.DateActivite, new { @class = "form-control", type = "date" })
        @Html.ValidationMessageFor(m => m.DateActivite, "", new { @class = "text-danger" })
    </div>

    <button type="submit" class="btn btn-success">Créer l'activité</button>
}